@model AttivaMente.Web.ViewModels.IscrizioniIndexViewModel

<h2>Iscrizioni - @Model.SelectedYear</h2>

<form method="get" asp-action="Index" class="mb-3 d-flex align-items-center gap-3 flex-wrap">
	<div class="d-flex align-items-center gap-2">
		<label class="form-label mb-0">Anno:</label>
		<select name="anno" class="form-select w-auto" onchange="this.form.submit()">
			@foreach (var year in Model.Years)
			{
				if (year == Model.SelectedYear)
				{
					<option value="@year" selected>@year</option>
				}
				else
				{
					<option value="@year">@year</option>
				}
			}
		</select>
	</div>

	<div class="d-flex align-items-center gap-2">
		<div class="form-check">
			<input class="form-check-input"
				   type="radio"
				   name="soloIscritti"
				   value="true"
				   @(Model.SoloIscritti ? "checked" : null)
				   onchange="this.form.submit()" />
			<label class="form-check-label">Solo Iscritti</label>
		</div>

		<div class="form-check">
			<input class="form-check-input"
				   type="radio"
				   name="soloIscritti"
				   value="false"
				   @(!Model.SoloIscritti ? "checked" : null)
				   onchange="this.form.submit()" />
			<label class="form-check-label">Tutti</label>
		</div>
	</div>
</form>

<table class="table table-striped table-bordered">
	<thead>
		<tr>
			<th>Cognome</th>
			<th>Nome</th>
			<th>Email</th>
			<th>Tipo</th>
			<th>Data Iscrizione</th>
			<th>Azioni</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var row in Model.Rows)
		{
			<tr>
				<td>@row.Cognome</td>
				<td>@row.Nome</td>
				<td>@row.Email</td>
				<td>@row.Tipo</td>
				<td>@(row.DataIscrizione?.ToString("dd/MM/yyyy"))</td>
				<td>
					@if (row.Azione == "Cancella")
					{
						<form method="post" asp-action="Delete">
							<input type="hidden" name="utenteId" value="@row.UtenteId" />
							<input type="hidden" name="anno" value="@Model.SelectedYear" />
							<input type="hidden" name="soloIscritti" value="@Model.SoloIscritti" />
							<button type="submit" class="btn btn-sm btn-outline-danger">Cancella</button>
						</form>
					}
					else if (row.Azione == "Rinnova")
					{
						<form method="post" asp-action="Renew">
							<input type="hidden" name="utenteId" value="@row.UtenteId" />
							<input type="hidden" name="anno" value="@Model.SelectedYear" />
							<input type="hidden" name="soloIscritti" value="@Model.SoloIscritti" />
							<button type="submit" class="btn btn-sm btn-outline-primary">Rinnova</button>
						</form>
					}
					else if (row.Azione == "Iscrivi")
					{
						<form method="post" asp-action="Subscribe">
							<input type="hidden" name="utenteId" value="@row.UtenteId" />
							<input type="hidden" name="anno" value="@Model.SelectedYear" />
							<input type="hidden" name="soloIscritti" value="@Model.SoloIscritti" />
							<button type="submit" class="btn btn-sm btn-outline-success">Iscrivi</button>
						</form>
					}
				</td>
			</tr>
		}
	</tbody>
</table>