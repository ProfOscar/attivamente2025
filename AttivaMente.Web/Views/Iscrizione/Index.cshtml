@using AttivaMente.Web.ViewModels
@model IscrizioniIndexViewModel

<h2>Iscrizioni - @Model.SelectedYear</h2>

<form method="get" asp-action="Index" class="mb-3 d-flex align-items-center gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-2">
        <label class="form-label mb-0">Anno:</label>
        <select name="anno" class="form-select w-auto" onchange="this.form.submit()">
            @foreach (var year in Model.Years)
            {
                <option value="@year" selected="@(year == Model.SelectedYear)">@year</option>
            }
        </select>
    </div>

    <div class="d-flex align-items-center gap-2">
        <div class="form-check">
            <input class="form-check-input" type="radio" name="isSoloIscritti" value="true"
                   checked="@(Model.IsSoloIscritti)" onchange="this.form.submit()" />
            <label class="form-check-label">Solo Iscritti</label>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="radio" name="isSoloIscritti" value="false"
                   checked="@(!Model.IsSoloIscritti)" onchange="this.form.submit()" />
            <label class="form-check-label">Tutti</label>
        </div>
    </div>

    <div>
        <label for="ricerca" class="form-label mb-1">Cerca</label>
        <input class="form-control" type="text" id="ricerca" name="ricerca" value="@Model.Ricerca"
               placeholder="Cognome e/o nome" style="min-width: 240px;" />
    </div>
    <div>
        <button class="btn btn-primary" type="submit">Cerca</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Cognome</th>
            <th>Nome</th>
            <th>Email</th>
            <th>Tipo</th>
            <th>Data Iscrizione</th>
            <th>AZIONI</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var row in Model.Rows)
        {
            <tr>
                <td>@row.Cognome</td>
                <td>@row.Nome</td>
                <td>@row.Email</td>
                <td>@row.Tipo</td>
                <td>@row.DataIscrizione?.ToString("dd/MM/yyyy")</td>
                <td>
                    @if (row.Azione == "Cancella")
                    {
                        // Richiama l'azione Delete del Controller
                        <form method="post" asp-action="Delete">
                            <input type="hidden" name="utenteId" value="@row.UtenteId" />
                            <input type="hidden" name="anno" value="@Model.SelectedYear" />
                            <input type="hidden" name="isSoloIscritti" value="@Model.IsSoloIscritti" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Cancella</button>
                        </form>
                    }
                    else if (row.Azione == "Rinnova")
                    {
                        // Richiama l'azione Renew del Controller
                        <form method="post" asp-action="Renew">
                            <input type="hidden" name="utenteId" value="@row.UtenteId" />
                            <input type="hidden" name="anno" value="@Model.SelectedYear" />
                            <input type="hidden" name="isSoloIscritti" value="@Model.IsSoloIscritti" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">Rinnova</button>
                        </form>
                    }
                    else
                    {
                        // Richiama l'azione Subscribe del Controller
                        <form method="post" asp-action="Subscribe">
                            <input type="hidden" name="utenteId" value="@row.UtenteId" />
                            <input type="hidden" name="anno" value="@Model.SelectedYear" />
                            <input type="hidden" name="isSoloIscritti" value="@Model.IsSoloIscritti" />
                            <button type="submit" class="btn btn-sm btn-outline-success">Iscrivi</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
